# Ollama (local LLM) — asegurate de tener Ollama corriendo: `ollama serve`
# Modelos recomendados con buen soporte de tool-calling: llama3.1, qwen2.5-coder, mistral-nemo
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# GitHub Personal Access Token (para REST API y MCP)
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat

# Puerto del servidor Hono
PORT=3001
