# Ollama (local LLM) — asegurate de tener Ollama corriendo: `ollama serve`
# Modelos recomendados con buen soporte de tool-calling: llama3.1, qwen2.5-coder, mistral-nemo
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# GitHub Personal Access Token (para REST API y MCP)
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat

# Puerto del servidor Hono
PORT=3001

# Model provider: "ollama" (default) o "bedrock"
MODEL_PROVIDER=ollama

# AWS Bedrock (solo si MODEL_PROVIDER=bedrock)
# Requisito previo: habilitar acceso al modelo en la consola de Bedrock
# → https://console.aws.amazon.com/bedrock/home#/modelaccess
#
# Elegí UNA de estas dos opciones de auth:
#
# Opción A — Bearer token (más simple, una sola variable):
#   Generá una API key en AWS Console → Bedrock → API keys y pegala en BEDROCK_API_KEY.
#   Dejá AWS_ACCESS_KEY_ID y AWS_SECRET_ACCESS_KEY vacíos (o borralos).
#
# Opción B — Credenciales AWS estándar (SigV4):
#   Completá AWS_ACCESS_KEY_ID y AWS_SECRET_ACCESS_KEY (los genera IAM en la consola).
#   Dejá BEDROCK_API_KEY vacío.
#   Alternativa: si ya tenés ~/.aws/credentials configurado, no hace falta setear nada acá —
#   el SDK resuelve solo. En ese caso podés dejar AWS_ACCESS_KEY_ID y AWS_SECRET_ACCESS_KEY vacíos.
AWS_REGION=us-east-1
BEDROCK_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0
