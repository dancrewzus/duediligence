---
// Client-side fetched — no props needed
---

<div id="portfolio-section">
  <div class="portfolio-header">
    <div class="hero-pill">
      <span class="hero-pill-dot"></span>
      <span>Historial persistente</span>
    </div>
    <h1 class="portfolio-title">Portfolio de <span>Análisis</span></h1>
    <p class="portfolio-subtitle">Historial de startups evaluadas — compara scores y evolución técnica.</p>
  </div>

  <div id="portfolio-loading" class="loading">
    <div class="spinner"></div>
    <p>Cargando portfolio...</p>
  </div>

  <div id="portfolio-empty" class="empty-state card" style="display: none;">
    <div class="empty-icon" aria-hidden="true">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
    </div>
    <p>No hay análisis previos. <a href="/">Analiza tu primera startup →</a></p>
  </div>

  <div id="portfolio-table-wrapper" style="display: none;">
    <div class="table-controls">
      <div class="sort-group">
        <button id="sort-score" class="btn-sort active">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 3v18h18"/>
            <path d="M7 14l4-4 4 4 5-5"/>
          </svg>
          <span>Por Score</span>
        </button>
        <button id="sort-date" class="btn-sort">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          <span>Por Fecha</span>
        </button>
      </div>
    </div>
    <div id="portfolio-list" class="portfolio-list"></div>
  </div>
</div>

<style>
  .portfolio-header {
    margin: 24px 0 40px;
    animation: heroIn 0.8s var(--ease-out) both;
  }

  @keyframes heroIn {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    margin-bottom: 18px;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text-secondary);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border-subtle);
    border-radius: 999px;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .hero-pill-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-cyan);
    box-shadow: 0 0 10px var(--accent-cyan);
    animation: pulseDot 2s ease-in-out infinite;
  }

  .portfolio-title {
    font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;
    font-size: clamp(2rem, 4vw, 2.6rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.1;
    margin-bottom: 8px;
  }

  .portfolio-title span {
    background: var(--grad-primary);
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: gradientShift 6s ease-in-out infinite;
    display: inline-block;
  }

  @keyframes gradientShift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .portfolio-subtitle {
    color: var(--text-secondary);
    font-size: 1rem;
    max-width: 560px;
  }

  .empty-state {
    text-align: center;
    padding: 64px 32px;
    color: var(--text-secondary);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .empty-icon {
    width: 72px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(110, 168, 255, 0.08);
    border: 1px solid var(--border-subtle);
    color: var(--accent-blue);
  }

  .table-controls {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
    margin-bottom: 18px;
  }

  .sort-group {
    display: inline-flex;
    padding: 4px;
    background: rgba(12, 12, 22, 0.5);
    border: 1px solid var(--border-subtle);
    border-radius: 999px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .btn-sort {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    font-size: 0.82rem;
    font-weight: 600;
    font-family: inherit;
    background: transparent;
    border: none;
    border-radius: 999px;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.25s var(--ease-out);
  }

  .btn-sort:hover {
    color: var(--text-primary);
  }

  .btn-sort.active {
    color: var(--text-primary);
    background: rgba(110, 168, 255, 0.15);
    box-shadow: inset 0 0 0 1px rgba(110, 168, 255, 0.3), 0 0 12px rgba(110, 168, 255, 0.15);
  }

  .portfolio-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .portfolio-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 26px;
    background: var(--bg-card);
    backdrop-filter: blur(20px) saturate(150%);
    -webkit-backdrop-filter: blur(20px) saturate(150%);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius);
    box-shadow: var(--shadow-card);
    transition: transform 0.3s var(--ease-out), border-color 0.3s var(--ease-out), background 0.3s var(--ease-out);
    cursor: default;
    position: relative;
    overflow: hidden;
    opacity: 0;
    animation: rowIn 0.5s var(--ease-out) forwards;
  }

  .portfolio-row:nth-child(1) { animation-delay: 0.04s; }
  .portfolio-row:nth-child(2) { animation-delay: 0.1s; }
  .portfolio-row:nth-child(3) { animation-delay: 0.16s; }
  .portfolio-row:nth-child(4) { animation-delay: 0.22s; }
  .portfolio-row:nth-child(5) { animation-delay: 0.28s; }
  .portfolio-row:nth-child(n+6) { animation-delay: 0.32s; }

  @keyframes rowIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .portfolio-row::before {
    content: '';
    position: absolute;
    left: 0;
    top: 20%;
    bottom: 20%;
    width: 3px;
    background: transparent;
    border-radius: 0 3px 3px 0;
    transition: background 0.3s var(--ease-out), top 0.3s var(--ease-out), bottom 0.3s var(--ease-out);
  }

  .portfolio-row:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-strong);
    transform: translateY(-2px);
  }

  .portfolio-row:hover::before {
    background: var(--grad-primary);
    top: 0;
    bottom: 0;
  }

  .portfolio-row-info {
    flex: 1;
    min-width: 0;
  }

  .portfolio-row-repo {
    font-family: 'Space Grotesk', 'Inter', sans-serif;
    font-weight: 700;
    font-size: 1.05rem;
    margin-bottom: 4px;
    letter-spacing: -0.02em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .portfolio-row-repo-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.25s var(--ease-out);
  }

  .portfolio-row-repo-link:hover {
    color: var(--accent-blue);
    text-decoration: underline;
    text-decoration-color: rgba(110, 168, 255, 0.5);
    text-underline-offset: 4px;
  }

  .portfolio-row-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .portfolio-row-meta svg {
    flex-shrink: 0;
  }

  .portfolio-duration {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 8px;
    font-family: 'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 0.7rem;
    font-variant-numeric: tabular-nums;
    color: var(--text-secondary);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border-subtle);
    border-radius: 999px;
  }

  .portfolio-row-summary {
    flex: 2;
    font-size: 0.85rem;
    color: var(--text-secondary);
    padding: 0 24px;
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .portfolio-row-score {
    font-family: 'Space Grotesk', 'Inter', sans-serif;
    font-size: 1.75rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.03em;
    min-width: 70px;
    text-align: right;
    filter: drop-shadow(0 0 14px currentColor);
  }

  @media (max-width: 768px) {
    .portfolio-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 14px;
    }
    .portfolio-row-summary {
      padding: 0;
      flex: none;
    }
    .portfolio-row-score {
      align-self: flex-end;
    }
  }
</style>

<script>
  const API_BASE = 'http://localhost:3001'

  const loadingEl = document.getElementById('portfolio-loading') as HTMLDivElement

  function escapeHtml(s: string): string {
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;')
  }
  const emptyEl = document.getElementById('portfolio-empty') as HTMLDivElement
  const tableWrapper = document.getElementById('portfolio-table-wrapper') as HTMLDivElement
  const listEl = document.getElementById('portfolio-list') as HTMLDivElement
  const sortScoreBtn = document.getElementById('sort-score') as HTMLButtonElement
  const sortDateBtn = document.getElementById('sort-date') as HTMLButtonElement

  interface PortfolioItem {
    repo: string
    repoUrl?: string
    fecha: string
    score: number
    duracionMs?: number
    descripcion?: string
    sintesisTecnica: string
    veredictoDetalle?: string
  }

  let portfolio: PortfolioItem[] = []
  let sortBy: 'score' | 'date' = 'score'

  function buildRepoUrl(item: PortfolioItem): string {
    return item.repoUrl ?? `https://github.com/${item.repo}`
  }

  function formatDuration(ms: number | undefined): string | null {
    if (typeof ms !== 'number' || ms <= 0) return null
    if (ms < 60_000) {
      const seconds = ms / 1000
      return `${seconds.toFixed(1)}s`
    }
    const totalSeconds = Math.round(ms / 1000)
    const minutes = Math.floor(totalSeconds / 60)
    const seconds = totalSeconds % 60
    return `${minutes}m ${seconds}s`
  }

  function getScoreColor(score: number): string {
    if (score > 7) return 'var(--score-good)'
    if (score >= 4) return 'var(--score-ok)'
    return 'var(--score-bad)'
  }

  function renderList() {
    const sorted = [...portfolio].sort((a, b) => {
      if (sortBy === 'score') return b.score - a.score
      return new Date(b.fecha).getTime() - new Date(a.fecha).getTime()
    })

    listEl.innerHTML = sorted
      .map((item) => {
        const fecha = new Date(item.fecha).toLocaleDateString('es-CL', {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
        })
        const calIcon = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`
        const dur = formatDuration(item.duracionMs)
        const durationPill = dur ? `<span class="portfolio-duration" title="Duración del análisis">⏱ ${escapeHtml(dur)}</span>` : ''
        const summary = (item.sintesisTecnica && item.sintesisTecnica.trim()) || (item.descripcion && item.descripcion.trim()) || 'Sin síntesis disponible.'
        return `
          <div class="portfolio-row">
            <div class="portfolio-row-info">
              <div class="portfolio-row-repo"><a class="portfolio-row-repo-link" href="${escapeHtml(buildRepoUrl(item))}" target="_blank" rel="noopener noreferrer">${escapeHtml(item.repo)}</a></div>
              <div class="portfolio-row-meta">
                ${calIcon}<span>${fecha}</span>
                ${durationPill}
              </div>
            </div>
            <div class="portfolio-row-summary">${escapeHtml(summary)}</div>
            <div class="portfolio-row-score" style="color: ${getScoreColor(item.score)}">
              ${item.score.toFixed(1)}
            </div>
          </div>
        `
      })
      .join('')
  }

  sortScoreBtn.addEventListener('click', () => {
    sortBy = 'score'
    sortScoreBtn.classList.add('active')
    sortDateBtn.classList.remove('active')
    renderList()
  })

  sortDateBtn.addEventListener('click', () => {
    sortBy = 'date'
    sortDateBtn.classList.add('active')
    sortScoreBtn.classList.remove('active')
    renderList()
  })

  async function loadPortfolio() {
    try {
      const res = await fetch(`${API_BASE}/api/portfolio`)
      portfolio = await res.json()

      loadingEl.style.display = 'none'

      if (portfolio.length === 0) {
        emptyEl.style.display = 'block'
      } else {
        tableWrapper.style.display = 'block'
        renderList()
      }
    } catch {
      loadingEl.style.display = 'none'
      emptyEl.style.display = 'block'
      emptyEl.querySelector('p')!.textContent = 'Error al cargar el portfolio. Verifica que el servidor este corriendo.'
    }
  }

  loadPortfolio()
</script>
